# ── Frontend (optional) ──────────────────────────────────────────────
# Public leaderboard via Supabase. WITHOUT these the app still works —
# scores just fall back to localStorage on the user's own device.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Serverless /api functions (server-side only — never exposed) ──────
# Gemini Flash: powers dynamic comprehension questions + Layer-B counting.
GEMINI_KEY=
# Anthropic: powers Layer-B Claude token count. Optional (shows "—" if absent).
ANTHROPIC_KEY=
